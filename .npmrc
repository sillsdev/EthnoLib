# Dependency-safety policy (requires npm >= 11.17.0; see volta/engines in package.json)

# 0. Refuse to run on an npm too old to honor the keys below (engines.npm in
#    package.json requires >=11.17.0). Without this, an old npm silently
#    ignores the entire policy.
engine-strict=true

# 1. Pin: write exact versions, never ^ or ~ ranges, on `npm install <pkg>`.
save-exact=true

# 2. Age: only install versions that have been published for more than 7 days.
#    Guards against compromised/yanked brand-new releases.
min-release-age=7

# 3. Install scripts: deny by default; hard-fail on any non-allowlisted script.
#    The allowlist itself lives in the "allowScripts" field of package.json
#    (npm rejects allow-scripts in .npmrc for project-scoped installs).
strict-allow-scripts=true

# 4. Sources: only allow registry installs. No git/url/tarball deps; directory
#    (workspace) deps permitted only from the repo root.
allow-git=none
allow-remote=none
allow-file=root
allow-directory=root
